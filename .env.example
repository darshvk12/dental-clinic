# ─── PureSmile Dental — Environment Variables ─────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Site ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://puresmile.in
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Email (choose one provider) ────────────────────────────────────

# Option 1: Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@puresmile.in

# Option 2: Nodemailer / SMTP
EMAIL_USER=darshvk05@gmail.com
EMAIL_PASS=Darsh*2005
CLINIC_EMAIL=darshvk05@gmail.com

# Option 3: SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxx

# ── Clinic notification email ──────────────────────────────────────
CLINIC_NOTIFICATION_EMAIL=clinic@example.com

# ── Google Maps ────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# ── Google Search Console ──────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp Business (optional) ──────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=919820012345

# ── CRM / Webhook (optional) ──────────────────────────────────────
# If you want to push appointments to a CRM like HubSpot or Zoho:
CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxxxx/xxxxxxx
